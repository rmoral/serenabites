# Stripe — Dashboard → Developers → API keys
#   Empieza por sk_test_ (modo test) o sk_live_ (producción)
STRIPE_SECRET_KEY=__paste_your_stripe_secret_key_here__

# Stripe Webhook — Dashboard → Developers → Webhooks → "Add endpoint"
#   URL: https://tu-dominio.com/api/stripe-webhook
#   Eventos a escuchar: checkout.session.completed
#   Empieza por whsec_
STRIPE_WEBHOOK_SECRET=__paste_your_webhook_signing_secret_here__

# Twilio WhatsApp — Console → Messaging → Try it out → Send a WhatsApp
# Sandbox para desarrollo; en producción, número aprobado por Meta.
TWILIO_ACCOUNT_SID=__paste_your_twilio_account_sid_here__
TWILIO_AUTH_TOKEN=__paste_your_twilio_auth_token_here__
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
RESTAURANT_WHATSAPP_TO=whatsapp:+34649575108

# Back-office — admin inicial (solo se usa la primera vez que arranca el server)
# Si dejas la password vacía, el server genera una aleatoria y la imprime UNA VEZ
# en los logs (journalctl -u serenabites).
ADMIN_INITIAL_EMAIL=admin@serenabites.com
ADMIN_INITIAL_PASSWORD=

# DB — opcional, por defecto data/serenabites.db
# DB_PATH=/var/www/serenabites/data/serenabites.db
